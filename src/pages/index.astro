---

<BaseLayout>
  <header class="site-header fixed inset-x-0 top-0 z-30 bg-transparent" data-site-header>
    <nav class="mx-auto flex h-16 max-w-7xl items-center px-5 sm:px-8" aria-label="Principal">
      <div class="site-brand">
        <a class="site-avatar" href="https://github.com/TaCodeC" target="_blank" rel="noreferrer" aria-label="GitHub de TaCodeC">
          <img src="/media/tacodec-github-avatar.png" alt="Avatar de GitHub de TaCodeC" width="400" height="400" />
        </a>
        <a class="site-wordmark" href="#top" aria-label="Inicio">tacodec</a>
      </div>
      <div class="nav-socials" aria-label="Redes y contacto" aria-hidden="true" data-nav-socials>
        <button
          class="hero-icon-button"
          type="button"
          aria-label="LinkedIn"
          data-tooltip="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.59 0 4.25 2.36 4.25 5.43v6.31h.03ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z"></path>
          </svg>
        </button>
        <a
          class="hero-icon-button"
          href="https://github.com/TaCodeC"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub de Fernando Cortés"
          data-tooltip="GitHub"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 0Z"></path>
          </svg>
        </a>
        <button
          class="hero-icon-button"
          type="button"
          aria-label="Copiar correo"
          data-copy-email={contactEmail}
          data-tooltip="Copiar correo"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M16 1H4a2 2 0 0 0-2 2v12h2V3h12V1Zm3 4H8a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm0 16H8V7h11v14Z"></path>
          </svg>
        </button>
      </div>
    </nav>
  </header>

  <main id="top" class="bg-carbon">
    <section class="hero-shell relative min-h-[92svh] overflow-clip pt-16 text-center">
      <video
        class="hero-video absolute inset-0 h-full w-full object-cover"
        src="/media/portfolio-hero.mp4"
        poster="/media/portfolio-hero-poster.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      ></video>
      <div class="hero-blackout pointer-events-none absolute inset-0"></div>
      <div class="hero-scan pointer-events-none absolute inset-0"></div>
      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-carbon to-transparent"></div>

      <div class="relative z-10 mx-auto flex min-h-[calc(92svh-4rem)] max-w-5xl flex-col items-center justify-center px-5 py-14 sm:px-8">
        <div class="hero-portrait" aria-hidden="true">
          <img src="/media/fernando-cortes.jpeg" alt="" width="800" height="800" />
        </div>

        <h1 class="mt-8 text-balance text-5xl font-black leading-none text-bone sm:text-7xl lg:text-8xl">
          Fernando Cortés
        </h1>

        <p class="hero-typewriter" data-role-style="technical" aria-live="polite">
          <span class="hero-typewriter-prompt" aria-hidden="true">&gt;</span>
          <span data-role-typewriter></span>
          <span class="hero-typewriter-caret" aria-hidden="true"></span>
        </p>

        <div class="hero-socials-dock mt-9" data-hero-socials-dock>
          <div class="hero-socials flex items-center justify-center gap-3" aria-label="Redes y contacto" data-hero-socials>
            <button
              class="hero-icon-button"
              type="button"
              aria-label="LinkedIn"
              data-tooltip="LinkedIn"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
