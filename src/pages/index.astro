      'Character asset': 'Character asset',
      'Cinemachine': 'Cinemachine',
      'Comunicacion visual': 'Visual communication',
      'Deploy institucional': 'Institutional deploy',
      'Artes Digitales': 'Digital Arts',
      'Promedio 9.4': 'GPA 9.4',
      'Animaciones': 'Animation',
      'Terror': 'Horror',
      '3 niveles': '3 levels',
      'Texturizaciones de monstruos grotescos para una experiencia de terror ambientada en una herreria embrujada.': 'Grotesque monster textures for a horror experience set in a haunted forge.',
      'Render de texturizado para robot, enfocado en lectura de materiales y presentacion final del asset.': 'Robot texturing render focused on material readability and final asset presentation.'
    };

    const normalizeText = (value) => value.replace(/\s+/g, ' ').trim();
    const translateToEnglish = () => {
      if (pageLanguage !== 'en') return;

      document.title = 'Fernando Cortes - Technical Artist';
      const metaDescription = document.querySelector('meta[name="description"]');
      metaDescription?.setAttribute(
        'content',
        'Fernando Cortes portfolio: technical art, shaders, Unity, OpenGL, modeling, and interactive experiences.'
      );

      document.querySelectorAll('[data-tooltip]').forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        const tooltip = element.dataset.tooltip;
        if (tooltip && englishText[tooltip]) {
          element.dataset.tooltip = englishText[tooltip];
        }
      });

      document.querySelectorAll('body *:not(script):not(style)').forEach((element) => {
        if (element.children.length > 0) return;
        const currentText = normalizeText(element.textContent || '');
        const translatedText = englishText[currentText];
        if (translatedText) {
          element.textContent = translatedText;
        }
      });
    };

    translateToEnglish();

    const roles =
      pageLanguage === 'en'
        ? ['Technical Artist', 'Programmer', '3D Modeling & Shaders']
        : ['Technical Artist', 'Programador', 'Modelado 3D y Shaders'];
    const copyLabels =
      pageLanguage === 'en'
        ? { copiedTooltip: 'Copied', copiedText: 'Email copied', failedTooltip: 'Could not copy', resetTooltip: 'Copy email' }
        : { copiedTooltip: 'Copiado', copiedText: 'Correo copiado', failedTooltip: 'No se pudo copiar', resetTooltip: 'Copiar correo' };
    const roleStyles = ['technical', 'code', 'lookdev'];
    const target = document.querySelector('[data-role-typewriter]');
    const typewriter = target?.closest('.hero-typewriter');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const heroShell = document.querySelector('.hero-shell');
    let scrollMotionFrame = 0;

    const updateScrollMotion = () => {
      scrollMotionFrame = 0;
      if (!(heroShell instanceof HTMLElement)) return;

      const progress = Math.min(1, Math.max(0, window.scrollY / Math.max(1, window.innerHeight)));
      heroShell.style.setProperty('--hero-scroll-progress', progress.toFixed(3));
    };

    if (!reduceMotion && heroShell instanceof HTMLElement) {
      updateScrollMotion();
      window.addEventListener(
        'scroll',
        () => {
          if (scrollMotionFrame) return;
          scrollMotionFrame = window.requestAnimationFrame(updateScrollMotion);
        },
        { passive: true }
      );
    }

    const revealItems = new Set();
    let revealObserver;
    let revealSyncFrame = 0;

    const addRevealItem = (element, direction = 'up', delay = 0) => {
      if (!(element instanceof HTMLElement) || revealItems.has(element)) return;

      element.classList.add('scroll-reveal');
      element.dataset.revealDirection = direction;
      element.style.setProperty('--reveal-delay', `${Math.min(delay, 420)}ms`);
      revealItems.add(element);
    };

    [
      ['#work .max-w-3xl', 'up', 0],
      ['#work > div > div > p.max-w-md', 'up', 80],
      ['#technologies .max-w-3xl', 'up', 0],
      ['#technologies > div > div > p.max-w-md', 'up', 80],
      ['.technology-panel-header', 'up', 0],
      ['.about-portrait-card', 'left', 0],
      ['.about-panel', 'right', 120],
      ['.trajectory-intro', 'left', 0],
      ['.trajectory-actions', 'up', 120],
      ['#contact .max-w-3xl', 'left', 0],
      ['.contact-copy-button', 'right', 120],
    ].forEach(([selector, direction, delay]) => {
      document.querySelectorAll(selector).forEach((element) => addRevealItem(element, direction, delay));
    });

    [
      ['.impact-grid', '.impact-card', 'up', 90],
      ['.technology-selector', '.technology-tab', 'scale', 70],
      ['.technology-projects', '.technology-project-card', 'up', 85],
      ['.about-tech-stack', '.about-tech-chip', 'scale', 42],
      ['.trajectory-timeline', '.trajectory-item', 'right', 75],
    ].forEach(([groupSelector, itemSelector, direction, step]) => {
      document.querySelectorAll(groupSelector).forEach((group) => {
        group.querySelectorAll(itemSelector).forEach((element, index) => {
          addRevealItem(element, direction, index * step);
        });
      });
    });

    const revealVisibleItems = () => {
      const viewportLimit = window.innerHeight * 0.94;

      revealItems.forEach((item) => {
        if (item.classList.contains('is-visible')) return;

        const rect = item.getBoundingClientRect();
        if (rect.top <= viewportLimit && rect.bottom >= 0) {
          item.classList.add('is-visible');
          revealObserver?.unobserve(item);
        }
      });
    };

    if (reduceMotion || !('IntersectionObserver' in window)) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
    } else {
      revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver?.unobserve(entry.target);
            }
          });
        },
        {
          rootMargin: '0px 0px -12% 0px',
          threshold: 0.12,
        }
      );

      revealItems.forEach((item) => revealObserver.observe(item));
      revealVisibleItems();
      window.addEventListener(
        'scroll',
        () => {
          if (revealSyncFrame) return;

          revealSyncFrame = window.requestAnimationFrame(() => {
            revealSyncFrame = 0;
            revealVisibleItems();
          });
        },
        { passive: true }
      );
      window.addEventListener('resize', revealVisibleItems);
    }

    if (target && reduceMotion) {
      target.textContent = roles[0];
    } else if (target) {
      let roleIndex = 0;
      let charIndex = 0;
      let deleting = false;

      const tick = () => {
        const role = roles[roleIndex];
        if (typewriter instanceof HTMLElement) {
          typewriter.dataset.roleStyle = roleStyles[roleIndex];
        }

        target.textContent = role.slice(0, charIndex);

        if (!deleting) {
          if (charIndex < role.length) {
            charIndex += 1;
            setTimeout(tick, 72);
            return;
          }

          deleting = true;
          setTimeout(tick, 1400);
          return;
        }

        if (charIndex > 0) {
          charIndex -= 1;
          setTimeout(tick, 42);
          return;
        }

        deleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        setTimeout(tick, 260);
      };

      tick();
    }

    document.querySelectorAll('[data-copy-email]').forEach((copyButton) => {
      copyButton.addEventListener('click', async (event) => {
        const button = event.currentTarget;
        const email = button instanceof HTMLElement ? button.dataset.copyEmail : '';

        if (!email || !(button instanceof HTMLElement)) return;

        try {
          await navigator.clipboard.writeText(email);
          const label = button.dataset.tooltip;
          const textTarget = button.querySelector('[data-copy-label]');
          const textLabel = textTarget?.textContent;
          button.dataset.tooltip = copyLabels.copiedTooltip;
          if (textTarget) textTarget.textContent = copyLabels.copiedText;
          window.setTimeout(() => {
            button.dataset.tooltip = label || copyLabels.resetTooltip;
            if (textTarget && textLabel) textTarget.textContent = textLabel;
          }, 1300);
        } catch {
          button.dataset.tooltip = copyLabels.failedTooltip;
        }
      });
    });

    const socialsDock = document.querySelector('[data-hero-socials-dock]');
    const socials = document.querySelector('[data-hero-socials]');
    const navSocials = document.querySelector('[data-nav-socials]');
    const siteHeader = document.querySelector('[data-site-header]');
    let socialsTrigger = 0;

    const updateSocialsTrigger = () => {
      if (!(socialsDock instanceof HTMLElement)) return;

      const navbarOffset = 16;
      socialsTrigger = socialsDock.getBoundingClientRect().top + window.scrollY - navbarOffset;
    };

    const updateSocialsDock = () => {
      if (!(socials instanceof HTMLElement) || !(navSocials instanceof HTMLElement)) return;

      const isDocked = window.scrollY >= socialsTrigger;
      socials.classList.toggle('is-hidden-by-nav', isDocked);
      navSocials.classList.toggle('is-visible', isDocked);
      siteHeader?.classList.toggle('has-docked-socials', isDocked);
      socials.setAttribute('aria-hidden', String(isDocked));
      navSocials.setAttribute('aria-hidden', String(!isDocked));
    };

    if (socialsDock && socials && navSocials) {
      updateSocialsTrigger();
      updateSocialsDock();
      window.addEventListener('scroll', updateSocialsDock, { passive: true });
      window.addEventListener('resize', () => {
        updateSocialsTrigger();
        updateSocialsDock();
      });
    }

    const activateSelectorTab = (tab) => {
      const group = tab.closest('[data-selector-group]');
      if (!group) return;

      const tabs = Array.from(group.querySelectorAll('[data-selector-tab]'));
      const activePanel = tab.getAttribute('aria-controls');
      const panels = tabs
        .map((item) => document.getElementById(item.getAttribute('aria-controls') || ''))
        .filter(Boolean);

      tabs.forEach((item) => {
        const isActive = item === tab;
        item.classList.toggle('is-active', isActive);
        item.setAttribute('aria-selected', String(isActive));
      });

      panels.forEach((panel) => {
        panel?.classList.toggle('is-active', panel.id === activePanel);
      });

      window.requestAnimationFrame(revealVisibleItems);
    };

    document.querySelectorAll('[data-selector-tab]').forEach((tab) => {
      tab.addEventListener('click', () => activateSelectorTab(tab));
    });

    document.querySelectorAll('[data-featured-project-target]').forEach((featuredProject) => {
      featuredProject.addEventListener('click', () => {
        if (!(featuredProject instanceof HTMLElement)) return;

        const technologyId = featuredProject.dataset.technologyTarget;
        const projectId = featuredProject.dataset.featuredProjectTarget;
        const technologyTab = document.querySelector(`[data-selector-tab][aria-controls="${technologyId}"]`);

        if (technologyTab instanceof HTMLElement) {
          activateSelectorTab(technologyTab);
        }

        window.requestAnimationFrame(() => {
          const projectCard = projectId ? document.getElementById(projectId) : null;
          const fallbackPanel = technologyId ? document.getElementById(technologyId) : null;
          const scrollTarget = projectCard || fallbackPanel;

          scrollTarget?.scrollIntoView({
            behavior: reduceMotion ? 'auto' : 'smooth',
            block: 'center',
          });

          if (projectCard instanceof HTMLElement) {
            projectCard.classList.add('is-highlighted');
            projectCard.focus({ preventScroll: true });
            window.setTimeout(() => {
              projectCard.classList.remove('is-highlighted');
            }, 1600);
          }
        });
      });
    });

    document.querySelectorAll('[data-carousel]').forEach((carousel) => {
      const slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
      const dots = Array.from(carousel.querySelectorAll('[data-carousel-dot]'));
      const thumbnails = Array.from(carousel.querySelectorAll('[data-carousel-thumb]'));
      const previous = carousel.querySelector('[data-carousel-prev]');
      const next = carousel.querySelector('[data-carousel-next]');
      let activeIndex = 0;

      const pauseHiddenVideos = () => {
        slides.forEach((slide) => {
          if (!slide.classList.contains('is-active')) {
            slide.querySelectorAll('video').forEach((video) => video.pause());
          }
        });
      };

      const setActiveSlide = (index) => {
        activeIndex = (index + slides.length) % slides.length;
        slides.forEach((slide, slideIndex) => {
          slide.classList.toggle('is-active', slideIndex === activeIndex);
        });
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('is-active', dotIndex === activeIndex);
        });
        thumbnails.forEach((thumbnail, thumbnailIndex) => {
          thumbnail.classList.toggle('is-active', thumbnailIndex === activeIndex);
        });
        pauseHiddenVideos();
      };

      previous?.addEventListener('click', () => setActiveSlide(activeIndex - 1));
      next?.addEventListener('click', () => setActiveSlide(activeIndex + 1));
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => setActiveSlide(index));
      });
      thumbnails.forEach((thumbnail, index) => {
        thumbnail.addEventListener('click', () => setActiveSlide(index));
      });
    });

    document.querySelectorAll('[data-sequence-viewer]').forEach((viewer) => {
      if (!(viewer instanceof HTMLElement)) return;

      const frames = Array.from(viewer.querySelectorAll('[data-sequence-frame]'));
      const slider = viewer.querySelector('[data-sequence-slider]');
      const previousFrame = viewer.querySelector('[data-sequence-prev]');
      const nextFrame = viewer.querySelector('[data-sequence-next]');
      const lightboxButton = viewer.querySelector('[data-open-lightbox]');
      const sequenceInterval = Number(viewer.dataset.sequenceInterval || 560);
      const playbackDelay = Number.isFinite(sequenceInterval) && sequenceInterval > 0 ? sequenceInterval : 560;
      let frameIndex = 0;
      let timer = 0;

      const setFrame = (index) => {
        frameIndex = (index + frames.length) % frames.length;
        frames.forEach((frame, currentIndex) => {
          frame.classList.toggle('is-active', currentIndex === frameIndex);
        });

        if (slider instanceof HTMLInputElement) {
          slider.value = String(frameIndex);
        }

        const activeFrame = frames[frameIndex];
        if (activeFrame instanceof HTMLImageElement) {
          const activeSource = activeFrame.currentSrc || activeFrame.src;
          viewer.dataset.lightboxSrc = activeSource;

          if (lightboxButton instanceof HTMLElement) {
            lightboxButton.dataset.lightboxSrc = activeSource;
          }
        }
      };

      const clearPlayback = () => {
        window.clearInterval(timer);
      };

      const stop = () => {
        clearPlayback();
        viewer.classList.add('is-paused');
      };

      const play = () => {
        clearPlayback();
        viewer.classList.remove('is-paused');
        timer = window.setInterval(() => setFrame(frameIndex + 1), playbackDelay);
      };

      viewer.addEventListener('mouseenter', stop);
      viewer.addEventListener('pointerenter', stop);
      viewer.addEventListener('mousemove', stop);
      viewer.addEventListener('pointermove', stop);

      const restartSequence = () => {
        clearPlayback();
        viewer.classList.remove('is-paused');
        setFrame(0);
        if (!reduceMotion) {
          play();
        }
      };

      viewer.addEventListener('mouseleave', restartSequence);
      viewer.addEventListener('pointerleave', restartSequence);

      slider?.addEventListener('input', () => {
        if (slider instanceof HTMLInputElement) {
          stop();
          setFrame(Number(slider.value));
        }
      });

      previousFrame?.addEventListener('click', () => {
        stop();
        setFrame(frameIndex - 1);
      });

      nextFrame?.addEventListener('click', () => {
        stop();
        setFrame(frameIndex + 1);
      });

      if (!reduceMotion) {
        play();
      } else {
        viewer.classList.add('is-paused');
      }
    });

    const lightbox = document.querySelector('[data-media-lightbox]');
    const lightboxBody = document.querySelector('[data-media-lightbox-body]');
    const closeLightbox = () => {
      if (!(lightbox instanceof HTMLElement) || !(lightboxBody instanceof HTMLElement)) return;

      lightbox.hidden = true;
      lightboxBody.replaceChildren();
      document.documentElement.classList.remove('has-lightbox');
    };

    const openLightbox = (source, type, alt) => {
      if (!(lightbox instanceof HTMLElement) || !(lightboxBody instanceof HTMLElement) || !source) return;

      lightboxBody.replaceChildren();

      if (type === 'video') {
        const video = document.createElement('video');
        video.src = source;
        video.controls = true;
        video.autoplay = true;
        video.playsInline = true;
        video.setAttribute('aria-label', alt || 'Video ampliado');
        lightboxBody.append(video);
      } else {
        const image = document.createElement('img');
        image.src = source;
        image.alt = alt || '';
        lightboxBody.append(image);
      }

      lightbox.hidden = false;
      document.documentElement.classList.add('has-lightbox');
    };

    document.querySelectorAll('[data-media-zoom-target]').forEach((zoomTarget) => {
      zoomTarget.addEventListener('dblclick', (event) => {
        if (!(zoomTarget instanceof HTMLElement)) return;

        if (event.target instanceof Element && event.target.closest('button, a, input, video, [data-open-lightbox]')) {
          return;
        }

        const rect = zoomTarget.getBoundingClientRect();
        const zoomX = rect.width > 0 ? ((event.clientX - rect.left) / rect.width) * 100 : 50;
        const zoomY = rect.height > 0 ? ((event.clientY - rect.top) / rect.height) * 100 : 50;
        zoomTarget.style.setProperty('--zoom-x', `${Math.min(100, Math.max(0, zoomX))}%`);
        zoomTarget.style.setProperty('--zoom-y', `${Math.min(100, Math.max(0, zoomY))}%`);
        zoomTarget.classList.toggle('is-zoomed');
      });
    });

    document.querySelectorAll('[data-open-lightbox]').forEach((openButton) => {
      openButton.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();

        if (!(openButton instanceof HTMLElement)) return;

        openLightbox(openButton.dataset.lightboxSrc, openButton.dataset.lightboxType, openButton.dataset.lightboxAlt);
      });
    });

    document.querySelectorAll('[data-media-lightbox-close]').forEach((closeButton) => {
      closeButton.addEventListener('click', closeLightbox);
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeLightbox();
      }
    });
  </script>
</BaseLayout>
