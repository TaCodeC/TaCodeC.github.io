                                <span class="border border-white/15 px-3 py-1 font-mono text-xs uppercase tracking-[0.14em] text-bone/70">
                                  {tag}
                                </span>
                              ))}
                            </div>
                            {(project.actions || (project.action ? [project.action] : [])).length > 0 && (
                              <div class="project-action-row">
                                {(project.actions || (project.action ? [project.action] : [])).map((action) =>
                                  action.href ? (
                                    <a class="project-action-button" data-action-tone={action.tone} href={action.href} target="_blank" rel="noreferrer">
