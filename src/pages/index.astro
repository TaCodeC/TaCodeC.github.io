                          <div class="technology-panel-languages">
                            {technology.languages.map((language) => (
                              <span class="technology-language-chip">
                                <img src={language.icon} alt="" width="20" height="20" loading="lazy" />
                                <span>{language.name}</span>
                              </span>
                            ))}
                          </div>
                        )
                      }
                    </div>
                    <div class="technology-panel-tags">
                      {technology.tags.map((tag) => (
                        <span class="border border-white/15 px-3 py-1 font-mono text-xs uppercase tracking-[0.14em] text-bone/70">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                  <div class="technology-projects">
                    {technology.projects.map((project) => (
                      <article id={project.id} class={`technology-project-card ${project.media ? 'has-rich-media' : ''}`} tabindex="-1">
                        {project.media && <ProjectMedia media={project.media} />}
                        <div class="technology-project-content">
